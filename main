        }
        .modal h2 { font-size: 28px; margin-bottom: 10px; }
        .modal p { font-size: 16px; color: #ccc; margin-bottom: 20px; }
        .modal .reward { font-size: 22px; color: #ffd700; font-weight: bold; margin-bottom: 20px; }
